#!/usr/bin/env bash
# Post-checkout hook: rebuild catalog, warn if stale
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
CATALOG_DIR="$SCRIPT_DIR/inventory"

if [ -f "$SCRIPT_DIR/scripts/catalog.sh" ]; then
  echo "Post-checkout: rebuilding catalog..."
  bash "$SCRIPT_DIR/scripts/catalog.sh" 2>/dev/null || echo "Post-checkout: catalog rebuild failed (non-fatal)"
fi

REGISTRY_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/cantrips/registry.json"
if [ -f "$REGISTRY_FILE" ]; then
  if [ -f "$SCRIPT_DIR/scripts/skills.sh" ]; then
    bash "$SCRIPT_DIR/scripts/skills.sh ls" 2>/dev/null || true
  fi
fi