{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Benchmark Results",
  "description": "Aggregated statistics for an eval iteration. Written to <workspace>/iteration-N/benchmark.json",
  "type": "object",
  "required": ["iteration", "run_summary"],
  "properties": {
    "iteration": {
      "type": "string",
      "description": "Directory name, e.g. iteration-1"
    },
    "eval_count": {
      "type": "integer",
      "description": "Number of unique evals in this iteration"
    },
    "run_summary": {
      "type": "object",
      "required": ["with_skill", "without_skill", "delta"],
      "properties": {
        "with_skill": { "$ref": "#/definitions/metrics" },
        "without_skill": { "$ref": "#/definitions/metrics" },
        "delta": {
          "type": "object",
          "description": "with_skill minus without_skill",
          "properties": {
            "pass_rate": { "type": "number" },
            "tokens": { "type": "number" },
            "time_seconds": { "type": "number" }
          }
        }
      }
    }
  },
  "definitions": {
    "metrics": {
      "type": "object",
      "properties": {
        "pass_rate": {
          "type": "object",
          "properties": {
            "mean": { "type": "number" },
            "stddev": { "type": "number" },
            "samples": { "type": "integer" }
          }
        },
        "tokens": {
          "type": "object",
          "properties": {
            "mean": { "type": "number" },
            "stddev": { "type": "number" },
            "samples": { "type": "integer" }
          }
        },
        "time_seconds": {
          "type": "object",
          "properties": {
            "mean": { "type": "number" },
            "stddev": { "type": "number" },
            "samples": { "type": "integer" }
          }
        }
      }
    }
  }
}
